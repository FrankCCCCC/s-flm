#!/bin/bash
#SBATCH -J ts-eval                                  # Job name
#SBATCH -o experiments/tinystories/eval_%j.out      # stdout (%j = jobID)
#SBATCH -e experiments/tinystories/eval_%j.err      # stderr (%j = jobID)
#SBATCH --mail-type=ALL                             # email on all state changes
#SBATCH --mail-user=sc3379@cornell.edu              # notification address
#SBATCH -N 1                                        # single node
#SBATCH -n 1                                        # single task
#SBATCH --partition=desa                            # desa Ampere node
#SBATCH --cpus-per-task=8                           # dataloader workers
#SBATCH --get-user-env                              # retrieve login environment
#SBATCH --mem=96gb                                  # host RAM
#SBATCH -t 8:00:00                                  # walltime
#SBATCH --gres=gpu:1                                # 1 GPU (eval is forward-only; single-device, no DDP)
#SBATCH --constraint="gpu-mid|gpu-high"             # any capable GPU (eval fits 24GB; cu128 needs sm_75+)

# Eval one TinyStories checkpoint: eval PPL (-> W&B) + GenPPL + samples (-> JSON).
# Pass MODEL_TYPE / CKPT / STEP_TAG via:  sbatch --export=ALL,MODEL_TYPE=sfm,CKPT=/abs/last.ckpt,STEP_TAG=30k eval.sub
export PATH=/home/sc3379/anaconda3/bin:$PATH
source activate sfm
export TMPDIR=/tmp
export SLURM_JOB_NAME=bash
export NCCL_P2P_DISABLE=1
export NCCL_IB_DISABLE=1

REPO_ROOT="/share/thickstun/sychou/workspace/research/s-flm-dev1/s-flm"
cd "${REPO_ROOT}"
bash scripts/sample/tinystories/eval.sh
# After eval, push the offline W&B run(s):
bash experiments/tinystories/sync_wandb.sh
